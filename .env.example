# -------------------------------------------------------------------------
#               Job Application Tracker – .env.example
#     Copy this file to .env and fill in your values
# -------------------------------------------------------------------------

# ── General ──────────────────────────────────────────────────────────────
PROJECT_NAME=Job Application Tracker
ENVIRONMENT=development               # development | production

# ── Backend ──────────────────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# ── Security ─────────────────────────────────────────────────────────────
SECRET_KEY=super-long-random-secret-key-change-this-in-production-abcdefghijklmnopqrstuvwxyz1234567890
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── PostgreSQL (used by docker-compose and backend) ──────────────────────
POSTGRES_SERVER=db                    # 'db' when using docker-compose, 'localhost' when local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=job_tracker
POSTGRES_PORT=5432

# Alternative: direct DATABASE_URL (takes precedence if set)
# DATABASE_URL=postgresql+asyncpg://postgres:your-secure-password-here@db:5432/job_tracker

# ── Frontend (Vite dev server) ───────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1

# ── Optional services you might add later ────────────────────────────────
# SMTP_TLS=true
# SMTP_PORT=587
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAILS_FROM_EMAIL=JobTracker <noreply@yourdomain.com>

# ── Production / deployment flags (optional) ─────────────────────────────
# ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
# CORS_ORIGINS=http://localhost:5173,https://yourfrontend.com
